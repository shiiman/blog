---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getPublishedPosts, type PublishedPost } from '../../lib/posts'

const posts = await getPublishedPosts() // 新しい順にソート済み
// 日付文字列の先頭(YYYY-MM)はJST壁時計の年月。これで月別にグルーピングする
const groups = new Map<string, { label: string; items: PublishedPost[] }>()
for (const post of posts) {
  const key = post.entry.data.date.slice(0, 7)
  const [y, mo] = key.split('-')
  const g = groups.get(key) ?? { label: `${+y}年${+mo}月`, items: [] }
  g.items.push(post)
  groups.set(key, g)
}
const months = [...groups.entries()]
---
<BaseLayout title="アーカイブ - shiimanblog" description="月別の記事アーカイブ">
  <h1 class="archive-title">アーカイブ</h1>
  {months.map(([key, m]) => (
    <section class="month" id={key}>
      <h2 class="month-title">{m.label}</h2>
      <ul class="post-list">
        {m.items.map((post) => (
          <li><a href={post.path}>{post.entry.data.title}</a></li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>

<style>
  .archive-title { font-size: 1.5rem; margin: 1rem 0 1.5rem; }
  .month { margin-bottom: 1.8rem; }
  .month-title {
    font-size: 1.1rem; margin: 0 0 0.6rem;
    padding-bottom: 0.3rem; border-bottom: 1px solid var(--border);
  }
  .post-list { list-style: none; margin: 0; padding: 0; }
  .post-list li { padding: 6px 0; }
  .post-list a { color: var(--text); }
  .post-list a:hover { color: var(--accent); text-decoration: none; }
</style>
